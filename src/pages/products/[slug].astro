---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductDetailClient from '../../components/react/ProductDetailClient.tsx';
import { PRODUCTS, INDUSTRIES } from '../../data';

const slug = Astro.params.slug;
const product = PRODUCTS.find(p => p.slug === slug);

if (!product) {
  return Astro.redirect('/products');
}

// Prepare lightweight data for client hydration (avoid shipping 18MB to browser)
const industriesLite = INDUSTRIES.map(i => ({ name: i.name, slug: i.slug }));
const similarProductsResolved = (product.similarProducts || []).map((s: string) => {
  const sp = PRODUCTS.find(p => p.slug === s);
  return sp ? { id: sp.id, name: sp.name, slug: sp.slug, cas: sp.cas, ec: sp.ec } : null;
}).filter(Boolean);
---

<BaseLayout title={`${product.name} | SoleChem Europe`} description={product.description?.substring(0, 160) || `${product.name} - CAS ${product.cas}. Request a quote from SoleChem Europe.`}>
  {/* JSON-LD Structured Data */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://solechem.com/" },
      { "@type": "ListItem", "position": 2, "name": "Products", "item": "https://solechem.com/products" },
      { "@type": "ListItem", "position": 3, "name": product.category, "item": `https://solechem.com/products?category=${encodeURIComponent(product.category)}` },
      { "@type": "ListItem", "position": 4, "name": product.name, "item": `https://solechem.com/products/${product.slug}` }
    ]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": product.name,
    "description": product.description?.substring(0, 200),
    "url": `https://solechem.com/products/${product.slug}`,
    "category": product.category,
    "brand": { "@type": "Brand", "name": "SoleChem" },
    "identifier": product.cas,
    "additionalProperty": [
      { "@type": "PropertyValue", "name": "CAS Number", "value": product.cas },
      ...(product.ec && product.ec !== "N/A" ? [{ "@type": "PropertyValue", "name": "EC Number", "value": product.ec }] : []),
      ...(product.formula ? [{ "@type": "PropertyValue", "name": "Chemical Formula", "value": product.formula }] : []),
      ...(product.mw && product.mw !== "N/A" ? [{ "@type": "PropertyValue", "name": "Molecular Weight", "value": product.mw }] : [])
    ],
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "seller": { "@type": "Organization", "name": "SoleChem" }
    }
  })} />

  <ProductDetailClient client:load product={product} industries={industriesLite} similarProducts={similarProductsResolved} />
</BaseLayout>
