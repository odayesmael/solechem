---
import Navbar from '../components/react/Navbar.tsx';
import Chatbot from '../components/react/Chatbot.tsx';
import WhatsAppFloat from '../components/react/WhatsAppFloat.tsx';
import ExitIntentPopup from '../components/react/ExitIntentPopup.tsx';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = 'SoleChem Europe | B2B Chemical Supplier & Manufacturer',
  description = 'Premium B2B chemical distributor and manufacturer based in Milan, Italy. 4,500+ products, ISO 9001 & ISO 22000 certified, serving 50+ countries.',
  ogImage = 'https://www.solechem.eu/solechem-logo-small.webp',
  canonical,
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = 'https://www.solechem.eu';
const canonicalUrl = canonical || `${siteUrl}${currentPath}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon .png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="SoleChem Europe" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "SoleChem Europe S.r.l.",
      "url": siteUrl,
      "logo": ogImage,
      "description": "Premium B2B chemical distributor and manufacturer based in Milan, Italy.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Via Leonardo da Vinci 9",
        "addressLocality": "Cassina de'Pecchi",
        "addressRegion": "MI",
        "postalCode": "20051",
        "addressCountry": "IT"
      },
      "telephone": "+390230556150",
      "email": "info@solechem.eu",
      "foundingDate": "2013",
      "sameAs": ["https://www.linkedin.com/company/solechem/"]
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="min-h-screen flex flex-col font-sans selection:bg-orange-600/30 selection:text-orange-900 dark:bg-slate-950 dark:text-slate-100 transition-colors duration-300">
      <Navbar client:load currentPath={currentPath} />
      <main class="flex-grow">
        <slot />
      </main>
      <!-- Footer -->
      <footer class="bg-slate-950 text-slate-400 relative overflow-hidden">
        {/* Orange accent top line */}
        <div class="h-1 bg-gradient-to-r from-orange-600 via-orange-500 to-orange-600"></div>

        {/* Decorative background elements */}
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-orange-600/[0.03] rounded-full blur-[120px] pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-slate-800/50 rounded-full blur-[100px] pointer-events-none"></div>

        {/* Main footer content */}
        <div class="max-w-7xl mx-auto px-4 lg:px-8 relative z-10">

          {/* Top section: CTA banner */}
          <div class="py-10 border-b border-slate-800/80 flex flex-col md:flex-row items-center justify-between gap-6">
            <div>
              <h3 class="text-white font-bold text-lg mb-1">Need a reliable chemical partner?</h3>
              <p class="text-slate-500 text-sm">Get a quote within 24 hours for any of our 2,800+ products.</p>
            </div>
            <a href="/contact" class="inline-flex items-center gap-2.5 bg-orange-600 hover:bg-orange-500 text-white px-7 py-3 font-bold text-sm uppercase tracking-wider transition-all hover:shadow-lg hover:shadow-orange-600/20 shrink-0">
              Request a Quote
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>

          {/* Main grid */}
          <div class="py-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">

            {/* Brand column */}
            <div class="lg:col-span-4 space-y-6">
              <a href="/" class="inline-block">
                <img src="https://www.solechem.eu/solechem-logo-small.webp" alt="SoleChem Logo" class="h-10 w-auto object-contain brightness-0 invert opacity-90" />
              </a>
              <p class="text-[14px] leading-relaxed max-w-xs text-slate-500">
                B2B chemical distributor and manufacturer based in Milan, Italy. Serving verified industrial buyers across 50+ countries since 2013.
              </p>

              {/* Social links */}
              <div class="flex gap-2 pt-1">
                <a href="https://www.linkedin.com/company/solechem/" target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-slate-800/80 hover:bg-orange-600 border border-slate-700/50 hover:border-orange-600 flex items-center justify-center text-slate-400 hover:text-white transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
                <a href="mailto:info@solechem.eu" class="w-9 h-9 bg-slate-800/80 hover:bg-orange-600 border border-slate-700/50 hover:border-orange-600 flex items-center justify-center text-slate-400 hover:text-white transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </a>
                <a href="https://wa.me/393884449559" target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-slate-800/80 hover:bg-green-600 border border-slate-700/50 hover:border-green-600 flex items-center justify-center text-slate-400 hover:text-white transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                </a>
              </div>
            </div>

            {/* Quick Links */}
            <div class="lg:col-span-2 lg:col-start-6">
              <h4 class="font-bold mb-5 text-white text-[11px] uppercase tracking-[0.2em]">Company</h4>
              <ul class="space-y-3">
                {[
                  { label: 'About Us', path: '/about' },
                  { label: 'Manufacturing', path: '/manufacturing' },
                  { label: 'News & Insights', path: '/news' },
                  { label: 'Sole Talent', path: '/sole-talent' },
                  { label: 'Contact', path: '/contact' },
                ].map(link => (
                  <li>
                    <a href={link.path} class="text-slate-500 hover:text-orange-400 text-[13px] font-medium transition-colors flex items-center gap-1.5 group">
                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700 group-hover:text-orange-500 transition-colors"><path d="m9 18 6-6-6-6"/></svg>
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            {/* Products Links */}
            <div class="lg:col-span-2">
              <h4 class="font-bold mb-5 text-white text-[11px] uppercase tracking-[0.2em]">Products</h4>
              <ul class="space-y-3">
                {[
                  { label: 'Product Catalog', path: '/products' },
                  { label: 'Industries', path: '/industries' },
                  { label: 'Categories', path: '/categories' },
                ].map(link => (
                  <li>
                    <a href={link.path} class="text-slate-500 hover:text-orange-400 text-[13px] font-medium transition-colors flex items-center gap-1.5 group">
                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700 group-hover:text-orange-500 transition-colors"><path d="m9 18 6-6-6-6"/></svg>
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            {/* Contact column */}
            <div class="lg:col-span-3">
              <h4 class="font-bold mb-5 text-white text-[11px] uppercase tracking-[0.2em]">Headquarters</h4>
              <ul class="space-y-4 text-[13px]">
                <li class="flex items-start gap-3">
                  <div class="w-8 h-8 bg-slate-800/80 border border-slate-700/50 flex items-center justify-center shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                  </div>
                  <div class="text-slate-500 leading-relaxed">
                    <span class="text-slate-300 font-medium block">Milan, Italy</span>
                    Via Leonardo da Vinci 9<br/>20051 Cassina de'Pecchi (MI)
                  </div>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-slate-800/80 border border-slate-700/50 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  </div>
                  <span class="text-slate-300 font-medium">+39 02 3055 6150</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-slate-800/80 border border-slate-700/50 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  </div>
                  <span class="text-slate-300 font-medium">info@solechem.eu</span>
                </li>
              </ul>
            </div>
          </div>

          {/* Certifications bar */}
          <div class="py-6 border-t border-slate-800/60 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
            {['ISO 9001:2015', 'ISO 22000:2018', 'REACH Compliant', 'GMP Certified'].map(cert => (
              <div class="flex items-center gap-2 text-[11px] font-bold text-slate-600 uppercase tracking-wider">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
                {cert}
              </div>
            ))}
          </div>

          {/* Bottom bar */}
          <div class="py-6 border-t border-slate-800/60 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-[12px] text-slate-600 font-medium">
              &copy; {new Date().getFullYear()} SoleChem Europe S.r.l. All rights reserved. <span class="text-orange-600 font-bold ml-1">B2B Only</span>
            </p>
            <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-[12px] font-medium text-slate-600">
              <a href="/privacy" class="hover:text-orange-400 transition-colors">Privacy Policy</a>
              <span class="text-slate-800">|</span>
              <a href="/legal-notice" class="hover:text-orange-400 transition-colors">Legal Notice</a>
              <span class="text-slate-800">|</span>
              <a href="/safety-handling" class="hover:text-orange-400 transition-colors">Safety &amp; Handling</a>
            </div>
          </div>
        </div>
      </footer>
      <Chatbot client:idle />
      <WhatsAppFloat client:idle />
      <ExitIntentPopup client:idle />
    </div>
  </body>
</html>
