---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | SoleChem Europe" description="The page you're looking for doesn't exist. Browse our chemical catalog or contact us for assistance.">
  <section class="min-h-[80vh] flex items-center justify-center bg-white">
    <div class="max-w-2xl mx-auto px-4 text-center py-20">
      {/* 404 number */}
      <div class="relative mb-8">
        <span class="text-[180px] md:text-[220px] font-black text-slate-100 leading-none select-none tracking-tighter">404</span>
        <div class="absolute inset-0 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#f57c00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
            <path d="M8.5 2h7"/>
            <path d="M7 16h10"/>
          </svg>
        </div>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-4">
        Page Not Found
      </h1>
      <p class="text-slate-500 text-[16px] leading-relaxed mb-10 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved. Try searching our catalog or navigate back to the homepage.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="inline-flex items-center justify-center gap-2 bg-orange-600 hover:bg-orange-700 text-white px-7 py-3 font-bold text-sm uppercase tracking-wider transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Homepage
        </a>
        <a href="/products" class="inline-flex items-center justify-center gap-2 bg-white border-2 border-slate-200 hover:border-orange-500 text-slate-700 hover:text-orange-600 px-7 py-3 font-bold text-sm uppercase tracking-wider transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          Browse Products
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white border-2 border-slate-200 hover:border-orange-500 text-slate-700 hover:text-orange-600 px-7 py-3 font-bold text-sm uppercase tracking-wider transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Contact Us
        </a>
      </div>

      {/* Quick links */}
      <div class="mt-16 pt-8 border-t border-slate-200">
        <p class="text-[11px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-4">Popular Pages</p>
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-2">
          {[
            { label: 'About Us', path: '/about' },
            { label: 'Industries', path: '/industries' },
            { label: 'Categories', path: '/categories' },
            { label: 'Manufacturing', path: '/manufacturing' },
            { label: 'News', path: '/news' },
          ].map(link => (
            <a href={link.path} class="text-sm text-slate-500 hover:text-orange-600 font-medium transition-colors">{link.label}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
