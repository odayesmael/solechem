---
import BaseLayout from '../layouts/BaseLayout.astro';
import { INDUSTRIES } from '../data';
import QuoteModal from '../components/react/QuoteModal.tsx';

const TRUSTED_LOGOS = [
  { src: '/logos/1-removebg-preview.png', alt: 'Partner 1' },
  { src: '/logos/2-removebg-preview.png', alt: 'Partner 2' },
  { src: '/logos/4-removebg-preview.png', alt: 'Partner 4' },
  { src: '/logos/5-removebg-preview.png', alt: 'Partner 5' },
  { src: '/logos/6-removebg-preview.png', alt: 'Partner 6' },
  { src: '/logos/7-removebg-preview.png', alt: 'Partner 7' },
  { src: '/logos/8-removebg-preview.png', alt: 'Partner 8' },
];

const FEATURED_CATEGORIES = [
  { name: "Agrochemicals", image: "/categories/Agrochemicals.webp", count: "45+ Products" },
  { name: "Alcohols & Glycols", image: "/categories/Alcohols & Glycols.webp", count: "120+ Products" },
  { name: "Alkalis & Bases", image: "/categories/Alkalis & Bases.webp", count: "85+ Products" },
  { name: "Amines", image: "/categories/Amines.webp", count: "150+ Products" },
  { name: "Amino Acids & Peptides", image: "/categories/Amino Acids & Peptides.webp", count: "60+ Products" },
  { name: "Catalysts & Catalyst Precursors", image: "/categories/Catalysts & Catalyst Precursors.webp", count: "90+ Products" },
  { name: "Chelating Agents", image: "/categories/Chelating Agents.webp", count: "110+ Products" },
  { name: "Flame Retardants", image: "/categories/Flame Retardants.webp", count: "45+ Products" },
  { name: "Flavors & Fragrances", image: "/categories/Flavors & Fragrances.webp", count: "20+ Products" },
  { name: "Heterocyclic Compounds", image: "/categories/Heterocyclic Compounds.webp", count: "35+ Products" },
  { name: "Inorganic Acids", image: "/categories/Inorganic Acids.webp", count: "50+ Products" },
  { name: "Monomers & Building Blocks", image: "/categories/Monomers & Building Blocks.webp", count: "75+ Products" },
];

const featuredIndustries = INDUSTRIES.slice(0, 8);
---

<BaseLayout title="SoleChem Europe | B2B Chemical Supplier & Manufacturer" description="Premium B2B chemical distributor and manufacturer based in Milan, Italy. 4,483+ products, ISO 9001 & ISO 22000 certified, serving 50+ countries.">
  <div class="flex flex-col">
    <!-- Hero Section -->
    <section class="relative min-h-[95vh] flex items-center pt-20 bg-slate-950 z-20">
      <div class="absolute inset-0 z-0 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-slate-950/70 via-slate-950/40 to-slate-950/10 z-10"></div>
        <img
          id="hero-bg-img"
          src="/slider.webp"
          alt="SoleChem Industrial Plant"
          class="w-full h-full object-cover opacity-80"
          style="animation: heroZoom 30s ease-in-out infinite alternate;"
          fetchpriority="high"
          decoding="async"
          width="1920"
          height="1080"
        />
        <!-- Decorative Elements -->
        <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-orange-600/20 rounded-full blur-[120px] z-10 pointer-events-none"></div>
        <div class="absolute bottom-1/4 left-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-[120px] z-10 pointer-events-none"></div>

        <!-- Floating chemical elements with parallax -->
        <div id="hero-floating" class="absolute inset-0 z-10 pointer-events-none transition-transform duration-700 ease-out">
          <!-- Hexagon icons -->
          <div class="hero-float absolute text-white opacity-0 transition-opacity duration-700" style="top: 15%; left: 10%;" data-dur="15" data-delay="0">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <div class="hero-float absolute text-white opacity-0 transition-opacity duration-700" style="top: 65%; left: 15%;" data-dur="20" data-delay="1">
            <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <div class="hero-float absolute text-white opacity-0 transition-opacity duration-700" style="top: 40%; left: 50%;" data-dur="14" data-delay="0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <div class="hero-float absolute text-white opacity-0 transition-opacity duration-700" style="top: 80%; left: 35%;" data-dur="17" data-delay="2.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="90" height="90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <div class="hero-float absolute text-white opacity-0 transition-opacity duration-700" style="top: 20%; left: 40%;" data-dur="12" data-delay="1.2">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <!-- Chemical formulas -->
          <span class="hero-float absolute text-white font-black tracking-tighter opacity-0 transition-opacity duration-700" style="top: 25%; left: 80%; font-size: 64px;" data-dur="18" data-delay="2">H&#8322;O</span>
          <span class="hero-float absolute text-white font-black tracking-tighter opacity-0 transition-opacity duration-700" style="top: 75%; left: 85%; font-size: 72px;" data-dur="16" data-delay="3">CO&#8322;</span>
          <span class="hero-float absolute text-white font-black tracking-tighter opacity-0 transition-opacity duration-700" style="top: 15%; left: 60%; font-size: 56px;" data-dur="22" data-delay="1.5">CH&#8324;</span>
          <span class="hero-float absolute text-white font-black tracking-tighter opacity-0 transition-opacity duration-700" style="top: 45%; left: 20%; font-size: 48px;" data-dur="19" data-delay="0.8">NH&#8323;</span>
          <span class="hero-float absolute text-white font-black tracking-tighter opacity-0 transition-opacity duration-700" style="top: 60%; left: 70%; font-size: 50px;" data-dur="25" data-delay="0.2">O&#8322;</span>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-4 w-full relative z-20 flex flex-col items-center text-center">
        <div class="w-full max-w-6xl space-y-8 flex flex-col items-center">
          <div class="inline-flex items-center gap-3 bg-white/10 px-3 py-1.5 rounded-sm backdrop-blur-md border border-white/20">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full bg-orange-500 opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 bg-orange-500"></span>
            </span>
            <span class="text-white/80 font-semibold text-[10px] uppercase tracking-[0.25em]">European Chemical Distribution</span>
          </div>

          <h1 class="text-5xl md:text-7xl lg:text-[5rem] font-sans font-bold text-white leading-[1.05] tracking-tight">
            Trusted Chemical <br />
            <span class="text-orange-500">Solutions.</span>
          </h1>

          <p class="text-lg md:text-xl text-white/80 leading-relaxed max-w-2xl font-light">
            SoleChem S.R.L. — your strategic partner for industrial chemicals. Sourcing and delivering over 4,483+ products globally.
          </p>

          <!-- Search Filter -->
          <div class="pt-8 pb-4 w-full max-w-5xl mx-auto relative z-30 flex justify-center">
            <form action="/products" method="get" class="bg-white p-2 md:p-3 rounded flex flex-col md:flex-row gap-2 shadow-2xl text-left relative w-full">
              <!-- Search Input -->
              <div class="relative w-full group flex-1">
                <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                </div>
                <input
                  type="text"
                  name="q"
                  placeholder="Search by CAS, Formula, or Name..."
                  class="w-full h-14 pl-12 pr-4 bg-slate-50 hover:bg-slate-100 text-slate-900 placeholder:text-slate-500 outline-none focus:bg-slate-100 rounded transition-all border border-transparent focus:border-slate-300"
                />
              </div>

              <div class="w-px bg-slate-200 hidden md:block mx-1"></div>

              <!-- Industry Dropdown -->
              <div class="relative md:w-64 group shrink-0">
                <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1"/><path d="M12 18h1"/><path d="M7 18h1"/></svg>
                </div>
                <select
                  name="industry"
                  class="w-full h-14 pl-12 pr-10 bg-slate-50 hover:bg-slate-100 text-slate-900 outline-none focus:bg-slate-100 rounded transition-all appearance-none cursor-pointer border border-transparent focus:border-slate-300 font-medium"
                >
                  <option value="">All Industries</option>
                  {INDUSTRIES.map(ind => (
                    <option value={ind.name}>{ind.name}</option>
                  ))}
                </select>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-4 top-1/2 -translate-y-1/2 rotate-90 pointer-events-none"><path d="m9 18 6-6-6-6"/></svg>
              </div>

              <button
                type="submit"
                aria-label="Search"
                class="bg-orange-600 hover:bg-orange-700 text-white w-full md:w-32 h-14 rounded flex items-center justify-center gap-2 transition-all active:scale-95 shrink-0 font-medium"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <span class="md:hidden">Search</span>
              </button>
            </form>
          </div>

          <!-- Stats Counters (static) -->
          <div class="grid grid-cols-3 gap-8 pb-16 w-full text-center max-w-4xl">
            <div>
              <div class="text-3xl md:text-4xl font-sans font-bold text-white">4,483+</div>
              <div class="text-[10px] text-white/50 uppercase font-semibold tracking-widest mt-2">Products</div>
            </div>
            <div>
              <div class="text-3xl md:text-4xl font-sans font-bold text-white">ISO</div>
              <div class="text-[10px] text-white/50 uppercase font-semibold tracking-widest mt-2">9001 & 22000</div>
            </div>
            <div>
              <div class="text-3xl md:text-4xl font-sans font-bold text-white">50+</div>
              <div class="text-[10px] text-white/50 uppercase font-semibold tracking-widest mt-2">Countries</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <div class="bg-slate-900 py-6 border-b border-slate-800 relative overflow-hidden transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-4 relative z-10">
        <div class="flex flex-wrap justify-between items-center gap-4">
          <div class="flex items-center gap-2 group cursor-default">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:stroke-orange-500 transition-colors"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
            <span class="text-slate-300 font-medium text-[13px] tracking-wide">ISO 9001:2015</span>
          </div>
          <div class="flex items-center gap-2 group cursor-default">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:stroke-orange-500 transition-colors"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            <span class="text-slate-300 font-medium text-[13px] tracking-wide">Global Sourcing</span>
          </div>
          <div class="flex items-center gap-2 group cursor-default">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:stroke-orange-500 transition-colors"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span class="text-slate-300 font-medium text-[13px] tracking-wide">Fast Fulfillment</span>
          </div>
          <div class="flex items-center gap-2 group cursor-default">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:stroke-orange-500 transition-colors"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-slate-300 font-medium text-[13px] tracking-wide">HQ in Milan, Italy</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Our Capabilities Section -->
    <section class="py-24 bg-slate-50 dark:bg-slate-950 relative overflow-hidden transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-4 relative z-10">
        <div class="mb-16 space-y-3">
          <h2 class="text-[10px] font-bold text-orange-600 dark:text-orange-500 uppercase tracking-[0.25em]">Our Capabilities</h2>
          <h3 class="text-3xl md:text-4xl font-sans font-bold text-slate-900 dark:text-white tracking-tight">Enterprise Solutions</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <!-- Reliability & Scale -->
          <div class="bg-white border border-slate-200 p-8 hover:bg-orange-600 group transition-colors duration-300 ease-out">
            <div class="w-10 h-10 bg-slate-100 group-hover:bg-orange-500 rounded flex items-center justify-center mb-10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700 group-hover:text-white transition-colors"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <h4 class="text-lg font-bold text-slate-900 group-hover:text-white mb-2 transition-colors">Reliability & Scale</h4>
            <p class="text-slate-600 text-[13px] leading-relaxed group-hover:text-white/80 transition-colors">We run complex supply chains with consistency. From drum quantities to full ISO tanks.</p>
          </div>

          <!-- Technical Excellence -->
          <div class="bg-white border border-slate-200 p-8 hover:bg-orange-600 group transition-colors duration-300 ease-out">
            <div class="w-10 h-10 bg-slate-100 group-hover:bg-orange-500 rounded flex items-center justify-center mb-10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700 group-hover:text-white transition-colors"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/><path d="M7 16h10"/></svg>
            </div>
            <h4 class="text-lg font-bold text-slate-900 group-hover:text-white mb-2 transition-colors">Technical Excellence</h4>
            <p class="text-slate-600 text-[13px] leading-relaxed group-hover:text-white/80 transition-colors">Laboratory-backed support ensuring quality control and strict specifications.</p>
          </div>

          <!-- Compliance First -->
          <div class="bg-white border border-slate-200 p-8 hover:bg-orange-600 group transition-colors duration-300 ease-out">
            <div class="w-10 h-10 bg-slate-100 group-hover:bg-orange-500 rounded flex items-center justify-center mb-10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700 group-hover:text-white transition-colors"><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/><circle cx="12" cy="8" r="6"/></svg>
            </div>
            <h4 class="text-lg font-bold text-slate-900 group-hover:text-white mb-2 transition-colors">Compliance First</h4>
            <p class="text-slate-600 text-[13px] leading-relaxed group-hover:text-white/80 transition-colors">REACH, GMP, ISO. We guarantee traceability across all global shipments.</p>
          </div>

          <!-- Strategic Partner -->
          <div class="bg-white border border-slate-200 p-8 hover:bg-orange-600 group transition-colors duration-300 ease-out">
            <div class="w-10 h-10 bg-slate-100 group-hover:bg-orange-500 rounded flex items-center justify-center mb-10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-700 group-hover:text-white transition-colors"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h4 class="text-lg font-bold text-slate-900 group-hover:text-white mb-2 transition-colors">Strategic Partner</h4>
            <p class="text-slate-600 text-[13px] leading-relaxed group-hover:text-white/80 transition-colors">Your dedicated contact for market insights, forecasting, and joint development.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Us Section -->
    <section class="py-32 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-col lg:flex-row gap-16 items-center">
          <div class="lg:w-1/2 space-y-8">
            <div class="space-y-4">
              <h2 class="text-xs font-black text-orange-600 uppercase tracking-[0.3em]">Why SoleChem</h2>
              <h3 class="text-4xl md:text-6xl font-black text-slate-950 tracking-tighter leading-[1.1]">
                Your Strategic <br />B2B Partner
              </h3>
              <p class="text-slate-500 text-lg max-w-lg leading-relaxed">
                We don't just sell chemicals; we provide supply chain continuity and technical expertise tailored to your industry needs.
              </p>
            </div>

            <div class="space-y-6 pt-4">
              <!-- Manufacturing & Custom Blends -->
              <div class="flex gap-6">
                <div class="w-14 h-14 shrink-0 bg-gray-50 rounded-2xl flex items-center justify-center border border-gray-100">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1"/><path d="M12 18h1"/><path d="M7 18h1"/></svg>
                </div>
                <div>
                  <h4 class="text-xl font-black text-slate-900 mb-2">Manufacturing & Custom Blends</h4>
                  <p class="text-slate-500 leading-relaxed">In-house laboratory for custom formulations, toll manufacturing, and white-label production.</p>
                </div>
              </div>

              <!-- Fast Logistics -->
              <div class="flex gap-6">
                <div class="w-14 h-14 shrink-0 bg-gray-50 rounded-2xl flex items-center justify-center border border-gray-100">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
                </div>
                <div>
                  <h4 class="text-xl font-black text-slate-900 mb-2">Fast Logistics</h4>
                  <p class="text-slate-500 leading-relaxed">48-72h delivery across Europe from our central hubs. EXW, DAP, and DDP terms available.</p>
                </div>
              </div>

              <!-- Technical Support -->
              <div class="flex gap-6">
                <div class="w-14 h-14 shrink-0 bg-gray-50 rounded-2xl flex items-center justify-center border border-gray-100">
