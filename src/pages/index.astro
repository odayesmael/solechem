  <!-- Hero floating elements: parallax + float animation -->
  <style>
    @keyframes heroZoom {
      0% { transform: scale(1) translate(0, 0); }
      100% { transform: scale(1.15) translate(-2%, -1%); }
    }
    @keyframes heroFloat {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-40px) rotate(15deg); }
    }
  </style>
  <script>
    (function() {
      const hero = document.querySelector('section.relative.min-h-\\[95vh\\]');
      const container = document.getElementById('hero-floating');
      const elements = document.querySelectorAll('.hero-float');
      if (!hero || !container || !elements.length) return;

      // Start float animations per element
      elements.forEach((el) => {
        const dur = parseFloat(el.getAttribute('data-dur') || '16');
        const delay = parseFloat(el.getAttribute('data-delay') || '0');
        el.style.animation = `heroFloat ${dur}s ease-in-out ${delay}s infinite`;
      });

      // Fade in on hover / scroll
      let visible = false;
      function show() {
        if (visible) return;
        visible = true;
        elements.forEach(el => el.style.opacity = '0.15');
      }
      function hide() {
        visible = false;
        elements.forEach(el => el.style.opacity = '0');
      }

      hero.addEventListener('mouseenter', show);
      hero.addEventListener('mouseleave', hide);

      // Also show on scroll
      const onScroll = () => {
        if (window.scrollY > 20) show();
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // Parallax: move container with mouse
      hero.addEventListener('mousemove', (e) => {
        const x = ((e as MouseEvent).clientX / window.innerWidth - 0.5) * 40;
        const y = ((e as MouseEvent).clientY / window.innerHeight - 0.5) * 40;
        container.style.transform = `translate(${x}px, ${y}px)`;
      });

      hero.addEventListener('mouseleave', () => {
        container.style.transform = 'translate(0, 0)';
      });
    })();
  </script>
