---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/react/ContactForm.tsx';
---

<BaseLayout title="Contact Us | SoleChem Europe" description="Speak directly with a technical expert. We respond to all B2B inquiries within 24 business hours.">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.solechem.eu/" },
      { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://www.solechem.eu/contact" }
    ]
  })} />
  <div class="min-h-screen bg-white">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-slate-200 bg-slate-50 pt-32 pb-20">
      <div class="absolute inset-0 z-0 opacity-5">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-slate-300 via-transparent to-transparent"></div>
      </div>

      <div class="max-w-7xl mx-auto px-4 lg:px-8 relative z-20 text-center space-y-8 max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-white border border-slate-200 px-3 py-1.5 rounded-sm shadow-sm">
          <span class="text-slate-600 font-bold text-[10px] uppercase tracking-[0.2em] flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            B2B Enquiries Welcome
          </span>
        </div>

        <h1 class="text-4xl md:text-6xl font-sans font-bold text-slate-900 tracking-tight leading-[1.1]">
          Contact <span class="text-orange-600">Us</span>
        </h1>

        <p class="text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto font-medium">
          Speak directly with a technical expert — not a call centre. We respond to all B2B inquiries within 24 business hours.
        </p>

        <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 pt-4">
          <span class="flex items-center gap-2 text-slate-600 text-[10px] font-bold uppercase tracking-widest bg-white px-3 py-1.5 rounded-sm border border-slate-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Under 24h Response
          </span>
          <span class="flex items-center gap-2 text-slate-600 text-[10px] font-bold uppercase tracking-widest bg-white px-3 py-1.5 rounded-sm border border-slate-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            EN/IT/DE/FR
          </span>
          <span class="flex items-center gap-2 text-slate-600 text-[10px] font-bold uppercase tracking-widest bg-white px-3 py-1.5 rounded-sm border border-slate-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/><path d="M7 16.5h10"/></svg>
            Qualified Chemists
          </span>
          <span class="flex items-center gap-2 text-slate-600 text-[10px] font-bold uppercase tracking-widest bg-white px-3 py-1.5 rounded-sm border border-slate-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            NDA on Request
          </span>
        </div>
      </div>
    </section>

    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 lg:px-8 flex flex-col lg:flex-row gap-8 lg:gap-12">
        <!-- Form Column -->
        <div class="flex-1">
          <div class="bg-white p-8 lg:p-12 rounded-sm border border-slate-200 shadow-sm">
            <ContactForm client:load />
          </div>
        </div>

        <!-- Sidebar Column -->
        <aside class="lg:w-[380px] space-y-6">
          <div class="bg-slate-900 p-8 rounded-sm text-white space-y-8 shadow-sm">
            <h4 class="text-[10px] font-bold text-orange-500 uppercase tracking-[0.2em] border-b border-slate-800 pb-2">Direct Contact</h4>
            <div class="space-y-6">
              <a href="tel:+390230556150" class="flex gap-4 hover:opacity-80 transition-opacity">
                <div class="w-10 h-10 bg-slate-800 rounded-sm flex items-center justify-center text-orange-500 shrink-0 border border-slate-700">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div>
                  <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">B2B Sales & Technical</p>
                  <p class="text-[15px] font-bold">+39 02 3055 6150</p>
                  <p class="text-[11px] text-slate-500 font-medium mt-1">Mon–Fri 9–18 CET</p>
                </div>
              </a>
              <a href="mailto:info@solechem.eu" class="flex gap-4 hover:opacity-80 transition-opacity">
                <div class="w-10 h-10 bg-slate-800 rounded-sm flex items-center justify-center text-orange-500 shrink-0 border border-slate-700">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <div>
                  <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Email</p>
                  <p class="text-[15px] font-bold text-orange-400">info@solechem.eu</p>
                  <p class="text-[11px] text-slate-500 font-medium mt-1">24h guaranteed response</p>
                </div>
              </a>
            </div>

            <div class="bg-[#25D366]/10 border border-[#25D366]/20 p-5 rounded-sm space-y-3">
              <div class="flex items-center gap-2 text-[#25D366]">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                <span class="font-bold text-[13px]">WhatsApp Business</span>
              </div>
              <p class="text-[12px] text-slate-400 leading-relaxed font-medium">Prefer a quick chat? We respond within 2 hours during business hours.</p>
              <a href="https://wa.me/390230556150" target="_blank" rel="noopener noreferrer" class="block w-full bg-[#25D366] hover:bg-[#20bd5a] text-white py-2 rounded-sm font-semibold text-[12px] uppercase tracking-widest text-center transition-colors">
                Chat on WhatsApp
              </a>
            </div>

            <div class="bg-orange-500/10 border border-orange-500/20 p-5 rounded-sm space-y-3">
              <div class="flex items-center gap-2 text-orange-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
                <span class="font-bold text-[13px]">Apply for Net 30/60</span>
              </div>
              <p class="text-[12px] text-slate-400 leading-relaxed font-medium">Credit terms available for approved B2B buyers in the EU.</p>
              <button class="w-full bg-slate-800 hover:bg-slate-700 text-white border border-slate-700 py-2 rounded-sm font-semibold text-[12px] uppercase tracking-widest transition-colors">
                Apply Now
              </button>
            </div>
          </div>

          <a href="https://www.google.com/maps/search/Via+Leonardo+da+Vinci+9,+20051+Cassina+de+Pecchi+MI+Italy" target="_blank" rel="noopener noreferrer" class="block bg-slate-50 p-6 rounded-sm border border-slate-200 space-y-5 shadow-sm hover:border-orange-500 transition-all group">
            <h4 class="text-[10px] font-bold text-slate-900 uppercase tracking-[0.2em] border-b border-slate-200 pb-2">Our Location</h4>
            <div class="aspect-video bg-slate-200 rounded-sm overflow-hidden relative border border-slate-300">
              <img
                src="https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?auto=format&fit=crop&q=80&w=800"
                alt="Milan Map"
                class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-8 h-8 bg-orange-600 rounded-sm flex items-center justify-center text-white shadow-sm border border-orange-700 group-hover:scale-110 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
              </div>
            </div>
            <div class="space-y-1 bg-white p-4 rounded-sm border border-slate-200 shadow-sm group-hover:border-orange-200 transition-colors">
              <p class="text-[14px] font-bold text-slate-900">SoleChem S.R.L.</p>
              <p class="text-[13px] text-slate-600 leading-relaxed font-medium">
                Via Leonardo da Vinci 9<br />
                20051 Cassina de'Pecchi (MI)<br />
                Italy
              </p>
              <p class="text-[11px] font-bold text-orange-600 uppercase tracking-widest pt-2">Open in Google Maps →</p>
            </div>
          </a>
        </aside>
      </div>
    </section>
  </div>
</BaseLayout>
