---
import Navbar from '../components/react/Navbar.tsx';
import Chatbot from '../components/react/Chatbot.tsx';
import WhatsAppFloat from '../components/react/WhatsAppFloat.tsx';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = 'SoleChem Europe | B2B Chemical Supplier & Manufacturer',
  description = 'Premium B2B chemical distributor and manufacturer based in Milan, Italy. 4,500+ products, ISO 9001 & ISO 22000 certified, serving 50+ countries.',
  ogImage = 'https://www.solechem.eu/solechem-logo-small.webp',
  canonical,
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = 'https://www.solechem.eu';
const canonicalUrl = canonical || `${siteUrl}${currentPath}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon .png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="SoleChem Europe" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "SoleChem Europe S.r.l.",
      "url": siteUrl,
      "logo": ogImage,
      "description": "Premium B2B chemical distributor and manufacturer based in Milan, Italy.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Via Leonardo da Vinci 9",
        "addressLocality": "Cassina de'Pecchi",
        "addressRegion": "MI",
        "postalCode": "20051",
        "addressCountry": "IT"
      },
      "telephone": "+390230556150",
      "email": "info@solechem.eu",
      "foundingDate": "2013",
      "sameAs": ["https://www.linkedin.com/company/solechem/"]
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="min-h-screen flex flex-col font-sans selection:bg-orange-600/30 selection:text-orange-900 dark:bg-slate-950 dark:text-slate-100 transition-colors duration-300">
      <Navbar client:load currentPath={currentPath} />
      <main class="flex-grow">
        <slot />
      </main>
      <Fragment>
        <footer class="bg-slate-50 text-slate-600 py-16 lg:py-20 border-t border-slate-200 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-orange-50/50 to-transparent pointer-events-none"></div>
          <div class="max-w-7xl mx-auto px-4 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-16">
              <div class="lg:col-span-4 space-y-6">
                <a href="/" class="inline-block">
                  <img src="https://www.solechem.eu/solechem-logo-small.webp" alt="SoleChem Logo" class="h-12 w-auto object-contain" />
                </a>
                <p class="text-[15px] leading-relaxed max-w-sm">
                  Premium B2B chemical distributor and manufacturer based in Milan, Italy. Providing verified industrial buyers with high-purity chemicals across 50+ countries since 2013.
                </p>
                <div class="flex gap-3">
                  <a href="https://www.linkedin.com/company/solechem/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-sm bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-orange-600 hover:border-orange-500 hover:bg-orange-50 transition-all shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                  </a>
                  <a href="mailto:info@solechem.eu" class="w-10 h-10 rounded-sm bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-orange-600 hover:border-orange-500 hover:bg-orange-50 transition-all shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
                  </a>
                </div>
              </div>
              <div class="lg:col-span-2 lg:col-start-7">
                <h4 class="font-bold mb-6 text-slate-900 text-[13px] uppercase tracking-widest">Navigation</h4>
                <ul class="space-y-4 text-[14px]">
                  {[
                    { label: 'Product Catalog', path: '/products' },
                    { label: 'Industries Served', path: '/industries' },
                    { label: 'Custom Manufacturing', path: '/manufacturing' },
                    { label: 'Company Profile', path: '/about' },
                    { label: 'B2B Contact', path: '/contact' },
                    { label: 'Sole Talent', path: '/sole-talent' },
                    { label: 'News & Insights', path: '/news' },
                  ].map(link => (
                    <li>
                      <a href={link.path} class="text-slate-600 hover:text-orange-600 font-medium transition-colors">
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="lg:col-span-3 lg:col-start-10">
                <h4 class="font-bold mb-6 text-slate-900 text-[13px] uppercase tracking-widest">Headquarters</h4>
                <ul class="space-y-5 text-[14px] text-slate-600 font-medium">
                  <li class="flex items-start gap-3">
                    <div class="bg-orange-100/50 p-2 rounded-sm shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    </div>
                    <span class="leading-snug pt-1">Via Leonardo da Vinci 9<br/>20051 Cassina de'Pecchi (MI), Italy</span>
                  </li>
                  <li class="flex items-center gap-3">
                    <div class="bg-orange-100/50 p-2 rounded-sm shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                    </div>
                    <span>+39 02 3055 6150</span>
                  </li>
                  <li class="flex items-center gap-3">
                    <div class="bg-orange-100/50 p-2 rounded-sm shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
                    </div>
                    <span>info@solechem.eu</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="pt-8 border-t border-slate-200 flex flex-col md:flex-row justify-between items-center gap-6">
              <p class="text-[13px] text-slate-500 font-medium">
                &copy; {new Date().getFullYear()} SoleChem Europe S.r.l. All rights reserved. <span class="text-slate-900 font-bold ml-1">B2B Only.</span>
              </p>
              <div class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-[13px] font-semibold text-slate-500">
                <a href="/privacy" class="hover:text-orange-600 transition-colors">Privacy Policy</a>
                <a href="/legal-notice" class="hover:text-orange-600 transition-colors">Legal Notice</a>
                <a href="/safety-handling" class="hover:text-orange-600 transition-colors">Safety &amp; Handling</a>
              </div>
            </div>
          </div>
        </footer>
      </Fragment>
      <Chatbot client:idle />
      <WhatsAppFloat client:idle />
    </div>
  </body>
</html>
